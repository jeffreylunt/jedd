# Jedd configuration. Copy to `.env`, fill in the REQUIRED block, then `docker compose up`.
# A standard setup (Sonarr :8989, Radarr :7878, Ollama :11434) needs only the REQUIRED values —
# everything below them is optional and has a sensible default (shown in each comment).

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED — the bot will not start without these.
# ═══════════════════════════════════════════════════════════════════════════

# Sonarr + Radarr API keys (each app: Settings > General > Security > API Key).
SONARR_API_KEY=
RADARR_API_KEY=

# Root folder paths AS SEEN BY your Sonarr/Radarr (Settings > Media Management > Root Folders).
SONARR_ROOT_FOLDER=/tv
RADARR_ROOT_FOLDER=/movies

# Your BlueBubbles server password.
BLUEBUBBLES_PASSWORD=

# The owner's phone number — full access, never spam-blocked. E.164 or US 10-digit.
# Access control is DEFAULT DENY: only OWNER_PHONE + ALLOWED_SENDERS (below) can use the bot;
# everyone else is silently ignored. Out of the box only the owner can reach Jedd.
OWNER_PHONE=+15551234567

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL — defaults shown; uncomment only to override.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Service URLs ───────────────────────────────────────────────────────────
# Where to reach each service. Defaults assume everything is on localhost.
#   - Same Docker network as your *arr stack: use the service names, e.g.
#       SONARR_URL=http://sonarr:8989/api/v3   RADARR_URL=http://radarr:7878/api/v3
#       OLLAMA_URL=http://ollama:11434
#   - Services on the Docker HOST (macOS/Windows Docker Desktop): use host.docker.internal.
#   - LinuxServer.io (lscr.io) Sonarr/Radarr images often serve under a /sonarr or /radarr base
#     path — if so, include it: http://sonarr:8989/sonarr/api/v3
#   default: http://localhost:8989/api/v3
# SONARR_URL=http://sonarr:8989/api/v3
#   default: http://localhost:7878/api/v3
# RADARR_URL=http://radarr:7878/api/v3
#   default: http://localhost:11434
# OLLAMA_URL=http://ollama:11434
#   default: http://localhost:1234
# BLUEBUBBLES_URL=http://host.docker.internal:1234

# ─── Ollama model ───────────────────────────────────────────────────────────
# Must support native tool/function calling. Pull it on the Ollama host first:
#   ollama pull qwen2.5:7b
#   default: qwen2.5:7b   (alias LOCAL_MODEL also accepted)
# OLLAMA_MODEL=qwen2.5:7b

# ─── Quality profiles (specific to YOUR arr instance) ───────────────────────
# The id is in the URL when editing a profile (Settings > Profiles).
#   default: 1
# SONARR_QUALITY_PROFILE_ID=1
# RADARR_QUALITY_PROFILE_ID=1

# ─── Inbound webhook ────────────────────────────────────────────────────────
# Port the receiver listens on.                                       default: 18790
# BLUEBUBBLES_WEBHOOK_PORT=18790
# Bind host. Inside a container use 0.0.0.0 so BlueBubbles can reach it.  default: 127.0.0.1
# BLUEBUBBLES_WEBHOOK_HOST=0.0.0.0
# The URL the BlueBubbles SERVER POSTs inbound messages to — must be reachable FROM the
# BlueBubbles host. In a container, set this to the Docker host's LAN IP (or use host networking).
#   default: http://<BLUEBUBBLES_WEBHOOK_HOST>:<BLUEBUBBLES_WEBHOOK_PORT>/webhook
# BLUEBUBBLES_WEBHOOK_URL=http://192.0.2.10:18790/webhook

# ─── Access control (DEFAULT DENY) ──────────────────────────────────────────
# Additional phone numbers allowed to use the bot (comma-separated), on top of OWNER_PHONE.
# Anyone NOT listed (and not the owner) is silently ignored. Empty = only the owner can use it.
#   default: (empty)
# ALLOWED_SENDERS=+15557654321,+15559876543
# Set true to open the bot to ANYONE who messages it (spam is still rate/pattern-blocked). When
# false (default), access is restricted to OWNER_PHONE + ALLOWED_SENDERS.
#   default: false
# ALLOW_ALL_SENDERS=false

# ─── General ────────────────────────────────────────────────────────────────
# The bot's display name / persona.                                  default: Jedd
# DISPLAY_NAME=Jedd
# Documented release-language preference (enforcement is via your arr Custom Formats — see README).
#   default: English
# PREFERRED_LANGUAGE=English
